# Copy this file to .env and fill in your values

# PostgreSQL connection string (required)
#
# Supabase: go to Project Settings > Database > Connection string (URI mode)
#   postgresql://postgres:YOUR_PASSWORD@db.XXXX.supabase.co:5432/postgres
#
# Local PostgreSQL:
#   postgresql://postgres:password@localhost:5432/love_app
#
# Other providers (Neon, Railway, etc.): copy the connection string from their dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/love_app

# Session secret — change this to any long random string
SESSION_SECRET=change-me-to-a-long-random-secret

# Optional: override default ports
# API_PORT=3001     (default — also set API_PORT in love-app if you change this)
# PORT=5173         (default for the frontend)
