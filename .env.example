# Copy this file to .env and fill in your values

# PostgreSQL connection string (required)
# Local example:  postgresql://postgres:password@localhost:5432/love_app
# Neon / Supabase / Railway: copy the connection string from their dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/love_app

# Session secret — change this to a long random string in production
SESSION_SECRET=change-me-to-a-long-random-secret

# Optional: override default ports
# API_PORT=3001     (default 3001 — also set API_PORT in love-app if you change this)
# PORT=5173         (default 5173 for the frontend)
